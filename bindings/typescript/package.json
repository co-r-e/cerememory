{
  "name": "@cerememory/sdk",
  "version": "0.2.3",
  "description": "TypeScript HTTP client SDK for the Cerememory REST API",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/co-r-e/cerememory.git",
    "directory": "bindings/typescript"
  },
  "keywords": [
    "cerememory",
    "memory",
    "ai",
    "cognitive",
    "sdk"
  ],
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
